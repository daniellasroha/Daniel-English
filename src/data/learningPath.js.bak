  {
    id: 11,
    judul: "Grammar: Kalimat Tanya",
    deskripsi: "Kuasai kata tanya What, Who, Where, When, Why, How untuk bertanya dalam bahasa Inggris",
    emoji: "❓",
    warna: "from-violet-400 to-purple-600",
    bg: "bg-violet-50",
    border: "border-violet-300",
    teks: "text-violet-700",
    level: "pemula",
    pelajaran: [
      {
        id: "11-1",
        judul: "Kata Tanya (5W + 1H)",
        emoji: "❓",
        tipe: "vocab",
        kartu: [
          { kata: "What",     arti: "Apa — menanyakan benda atau hal",            emoji: "📦", contoh: "What is your name?" },
          { kata: "Who",      arti: "Siapa — menanyakan orang",                   emoji: "👤", contoh: "Who is that girl?" },
          { kata: "Where",    arti: "Di mana — menanyakan tempat",                emoji: "📍", contoh: "Where do you live?" },
          { kata: "When",     arti: "Kapan — menanyakan waktu",                   emoji: "📅", contoh: "When is your birthday?" },
          { kata: "Why",      arti: "Mengapa — menanyakan alasan",                emoji: "🤔", contoh: "Why are you sad?" },
          { kata: "How",      arti: "Bagaimana — menanyakan cara atau kondisi",   emoji: "💭", contoh: "How are you?" },
          { kata: "How many", arti: "Berapa banyak — untuk benda yang bisa dihitung", emoji: "🔢", contoh: "How many students are there?" },
          { kata: "How much", arti: "Berapa harga / seberapa banyak (tak terhitung)", emoji: "💰", contoh: "How much is this shirt?" },
        ],
        soal: [
          { pertanyaan: "Kata tanya untuk menanyakan TEMPAT adalah...", pilihan: ["What", "Who", "Where", "When"], jawaban: 2 },
          { pertanyaan: "'___ is your birthday?' — Kata tanya untuk waktu:", pilihan: ["Where", "When", "Why", "Who"], jawaban: 1 },
          { pertanyaan: "Apa arti 'Why'?", pilihan: ["Apa", "Siapa", "Di mana", "Mengapa"], jawaban: 3 },
          { pertanyaan: "Menanyakan jumlah benda: 'How ___ apples are there?'", pilihan: ["much", "many", "more", "most"], jawaban: 1 },
          { pertanyaan: "'Who is that girl?' — Kalimat ini menanyakan...", pilihan: ["Benda", "Tempat", "Orang", "Waktu"], jawaban: 2 },
        ],
      },
      {
        id: "11-2",
        judul: "Membuat Kalimat Tanya",
        emoji: "💬",
        tipe: "vocab",
        kartu: [
          { kata: "What do you like?",      arti: "Apa yang kamu suka? — What + do/does + S + V?",            emoji: "❓", contoh: "What do you eat for breakfast?" },
          { kata: "Where do you live?",     arti: "Di mana kamu tinggal? — Where + do + S + V?",              emoji: "📍", contoh: "Where does she study?" },
          { kata: "Why do you study English?", arti: "Mengapa kamu belajar bahasa Inggris? — Why + do + S + V?", emoji: "🤔", contoh: "Why does he come late?" },
          { kata: "How do you go to school?",  arti: "Bagaimana kamu pergi ke sekolah? — How + do + S + V?", emoji: "🏫", contoh: "How does she go to work?" },
          { kata: "Who is your teacher?",   arti: "Siapa gurumu? — Who + To Be + S?",                         emoji: "👩", contoh: "Who is your best friend?" },
          { kata: "When does school start?",arti: "Kapan sekolah dimulai? — When + does + S + V?",            emoji: "📅", contoh: "When do you wake up?" },
        ],
        soal: [
          { pertanyaan: "Melengkapi: '___ do you live?' (Di mana)", pilihan: ["What", "When", "Where", "Who"], jawaban: 2 },
          { pertanyaan: "Kalimat tanya yang benar:", pilihan: ["You where live?", "Where you live?", "Where do you live?", "Where lives you?"], jawaban: 2 },
          { pertanyaan: "'Why do you study English?' — Kalimat ini menanyakan...", pilihan: ["Tempat belajar", "Cara belajar", "Waktu belajar", "Alasan belajar"], jawaban: 3 },
          { pertanyaan: "Melengkapi: '___ is your teacher?' (Siapa)", pilihan: ["What", "Who", "How", "When"], jawaban: 1 },
          { pertanyaan: "'How do you go to school?' — Kalimat ini menanyakan...", pilihan: ["Tempat sekolah", "Waktu pergi", "Cara pergi ke sekolah", "Siapa yang pergi"], jawaban: 2 },
        ],
      },
      {
        id: "11-3",
        judul: "Kuis: Kalimat Tanya",
        emoji: "🧠",
        tipe: "quiz",
        soal: [
          { pertanyaan: "Kata tanya untuk menanyakan ORANG adalah...", pilihan: ["What", "Where", "Who", "How"], jawaban: 2 },
          { pertanyaan: "'___ is your name?' — Kata tanya yang tepat:", pilihan: ["Where", "When", "Who", "What"], jawaban: 3 },
          { pertanyaan: "Apa arti 'How many'?", pilihan: ["Berapa harga", "Bagaimana", "Berapa banyak", "Kapan"], jawaban: 2 },
          { pertanyaan: "Kalimat tanya yang benar: '___ does he go to school?'", pilihan: ["What", "How", "Who", "Where"], jawaban: 1 },
          { pertanyaan: "'Why are you sad?' — Kalimat ini menanyakan...", pilihan: ["Waktu", "Tempat", "Siapa", "Alasan"], jawaban: 3 },
          { pertanyaan: "Urutan kalimat tanya yang benar:", pilihan: ["You do where live?", "Where you do live?", "Where do you live?", "Do you where live?"], jawaban: 2 },
        ],
      },
