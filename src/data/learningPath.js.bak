  // ═══════════════════════════════════════════════════════════
  // UNIT 8 — Grammar: Simple Present Tense
  // ═══════════════════════════════════════════════════════════
  {
    id: 8,
    judul: "Grammar: Simple Present",
    deskripsi: "Kuasai Simple Present Tense — cara membuat kalimat tentang kebiasaan dan fakta",
    emoji: "📖",
    warna: "from-indigo-400 to-indigo-600",
    bg: "bg-indigo-50",
    border: "border-indigo-300",
    teks: "text-indigo-700",
    level: "pemula",
    pelajaran: [
      {
        id: "8-1",
        judul: "Rumus Simple Present",
        emoji: "📝",
        tipe: "vocab",
        kartu: [
          { kata: "I eat rice every day.",      arti: "Saya makan nasi setiap hari. — Rumus: S + V1 (kata kerja dasar)", emoji: "📝", contoh: "I drink coffee in the morning." },
          { kata: "You study English.",          arti: "Kamu belajar bahasa Inggris. — You + kata kerja dasar",           emoji: "📖", contoh: "You play football after school." },
          { kata: "We live in Jakarta.",         arti: "Kami tinggal di Jakarta. — We/They + kata kerja dasar",           emoji: "🏠", contoh: "They go to school by bus." },
          { kata: "He studies every night.",     arti: "Dia (pria) belajar setiap malam. — He/She/It + V1 + s/es",       emoji: "💡", contoh: "She reads books." },
          { kata: "She eats breakfast daily.",   arti: "Dia (wanita) makan pagi setiap hari. — Tambah -s setelah verb",  emoji: "🍳", contoh: "He works in a hospital." },
          { kata: "Kata kunci: always, usually, often, every day", arti: "Tanda-tanda Simple Present: selalu, biasanya, sering, setiap hari", emoji: "🔑", contoh: "I always wake up early." },
        ],
        soal: [
          { pertanyaan: "Simple Present digunakan untuk...", pilihan: ["Kejadian masa lalu", "Kebiasaan dan fakta sehari-hari", "Rencana masa depan", "Kejadian sekarang ini"], jawaban: 1 },
          { pertanyaan: "Pilih kalimat Simple Present yang benar:", pilihan: ["I eats rice.", "She eat rice.", "He eats rice.", "They eats rice."], jawaban: 2 },
          { pertanyaan: "Untuk He/She/It, kata kerja mendapat...", pilihan: ["Tidak berubah", "Tambah -ed", "Tambah -ing", "Tambah -s/-es"], jawaban: 3 },
          { pertanyaan: "Kata kunci Simple Present: 'every day' artinya...", pilihan: ["Kemarin", "Besok", "Setiap hari", "Sekarang"], jawaban: 2 },
          { pertanyaan: "'She ___ to school every day.' — Kata kerja yang benar:", pilihan: ["go", "goes", "going", "went"], jawaban: 1 },
        ],
      },
      {
        id: "8-2",
        judul: "Simple Present: Negatif & Tanya",
        emoji: "❓",
        tipe: "vocab",
        kartu: [
          { kata: "I do not like fish.",      arti: "Saya tidak suka ikan. — Negatif: S + do not + V1 (I/You/We/They)",      emoji: "❌", contoh: "I do not eat spicy food." },
          { kata: "He does not like fish.",   arti: "Dia tidak suka ikan. — Negatif: S + does not + V1 (He/She/It)",         emoji: "❌", contoh: "She does not drink coffee." },
          { kata: "Do you like coffee?",      arti: "Apakah kamu suka kopi? — Tanya: Do + S + V1? (I/You/We/They)",         emoji: "❓", contoh: "Do they live here?" },
          { kata: "Does she like tea?",       arti: "Apakah dia suka teh? — Tanya: Does + S + V1? (He/She/It)",             emoji: "❓", contoh: "Does he study English?" },
          { kata: "do not = don't",            arti: "Singkatan: do not → don't — lebih umum digunakan",                    emoji: "💡", contoh: "I don't eat meat." },
          { kata: "does not = doesn't",        arti: "Singkatan: does not → doesn't — lebih umum digunakan",               emoji: "💡", contoh: "She doesn't like durian." },
        ],
        soal: [
          { pertanyaan: "Kalimat negatif untuk 'I like fish' adalah...", pilihan: ["I not like fish.", "I does not like fish.", "I do not like fish.", "I am not like fish."], jawaban: 2 },
          { pertanyaan: "Kalimat tanya untuk 'She likes coffee' adalah...", pilihan: ["Do she likes coffee?", "Does she like coffee?", "She does like coffee?", "Is she like coffee?"], jawaban: 1 },
          { pertanyaan: "Singkatan 'do not' adalah...", pilihan: ["doen't", "don't", "do'nt", "dont"], jawaban: 1 },
          { pertanyaan: "Isi yang benar: 'He ___ not drink coffee.'", pilihan: ["do", "am", "are", "does"], jawaban: 3 },
          { pertanyaan: "'Does she speak English?' — Ini kalimat...", pilihan: ["Positif", "Negatif", "Tanya", "Perintah"], jawaban: 2 },
        ],
      },
      {
        id: "8-3",
        judul: "Kuis: Simple Present Tense",
        emoji: "🧠",
        tipe: "quiz",
        soal: [
          { pertanyaan: "Pilih yang benar untuk She: 'She ___ every morning.'", pilihan: ["run", "runs", "running", "ran"], jawaban: 1 },
          { pertanyaan: "Buat kalimat negatif: 'I ___ not eat meat.'", pilihan: ["is", "am", "does", "do"], jawaban: 3 },
          { pertanyaan: "Pilih kalimat Simple Present yang benar:", pilihan: ["He go to school.", "He goes to school.", "He going to school.", "He gone to school."], jawaban: 1 },
          { pertanyaan: "Kalimat tanya untuk 'They play football':", pilihan: ["Do they play football?", "Does they play football?", "They do play football?", "Play they football?"], jawaban: 0 },
          { pertanyaan: "'She doesn't like durian.' — Artinya:", pilihan: ["Dia suka durian.", "Apakah dia suka durian?", "Dia tidak suka durian.", "Dia sedang makan durian."], jawaban: 2 },
          { pertanyaan: "Kata kunci yang menandakan Simple Present:", pilihan: ["Yesterday", "Tomorrow", "Right now", "Every day"], jawaban: 3 },
        ],
      },
    ],
  },

